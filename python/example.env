# .env file used by load_dotenv to insert environment variables in the jupter environment
# copy example.env to .env

# --- OpenAI (L1_fast_agent.ipynb and other lessons) — https://platform.openai.com/
OPENAI_API_KEY=your_openai_api_key_here
# Optional: custom API base URL (Azure OpenAI, proxies, OpenAI-compatible gateways)
# OPENAI_API_BASE=https://api.openai.com/v1

# --- LangSmith (optional tracing) — https://smith.langchain.com/
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=lc-essentials

# --- Groq (L1_fast_agent_groq.ipynb) — https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here
# Optional: tool-capable model id from Groq docs
# GROQ_MODEL=llama-3.3-70b-versatile

# --- Cloudflare Workers AI (L1_fast_agent_cloudflare.ipynb) — https://developers.cloudflare.com/workers-ai/
# Use an API token with Workers AI access (see Cloudflare dashboard → API Tokens).
CF_AI_API_TOKEN=your_cloudflare_api_token_here
CF_ACCOUNT_ID=your_cloudflare_account_id_here
# Optional: Workers AI model binding
# CF_WORKERS_AI_MODEL=@cf/meta/llama-3.3-70b-instruct-fp8-fast
